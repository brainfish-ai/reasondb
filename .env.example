# LLM Provider Configuration (required)
# Supported: openai, anthropic, gemini, cohere, glm, kimi, ollama, vertex, bedrock
REASONDB_LLM_PROVIDER=openai
REASONDB_LLM_API_KEY=your-api-key-here

# Override the default model for the provider (optional)
# REASONDB_MODEL=gpt-4o-mini

# Ollama configuration (only used when REASONDB_LLM_PROVIDER=ollama)
# REASONDB_OLLAMA_BASE_URL=http://localhost:11434/v1
# REASONDB_MODEL=llama3.3

# Vertex AI: set base URL and use API key as Google Cloud access token
# REASONDB_LLM_PROVIDER=vertex
# REASONDB_LLM_BASE_URL=https://LOCATION-aiplatform.googleapis.com/v1/projects/PROJECT_ID/locations/LOCATION/endpoints/openapi
# REASONDB_LLM_API_KEY=$(gcloud auth print-access-token)

# AWS Bedrock: set region (or use AWS_REGION); uses default credential chain
# REASONDB_LLM_PROVIDER=bedrock
# REASONDB_LLM_REGION=us-east-1
# REASONDB_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
