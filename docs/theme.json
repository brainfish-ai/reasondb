{
  "$schema": "https://devdoc.sh/theme.json",
  "logo": {
    "light": "/assets/logo-light.svg",
    "dark": "/assets/logo-dark.svg",
    "alt": "ReasonDB",
    "width": 32,
    "height": 32
  },
  "header": {
    "showAskAI": true,
    "showSearch": true,
    "showThemeToggle": true
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/reasondb/reasondb",
        "external": true
      }
    ]
  },
  "colors": {
    "primary": "#F56565",
    "primaryLight": "#FC8181",
    "primaryDark": "#F56565",
    "background": {
      "light": "#fafafa",
      "dark": "#0f0f0f"
    },
    "backgroundSecondary": {
      "light": "#f5f5f5",
      "dark": "#171717"
    },
    "card": {
      "light": "#ffffff",
      "dark": "#1c1c1c"
    },
    "border": {
      "light": "#e5e5e5",
      "dark": "#2a2a2a"
    },
    "text": {
      "light": "#171717",
      "dark": "#ededed"
    },
    "textMuted": {
      "light": "#737373",
      "dark": "#a3a3a3"
    },
    "accent": {
      "light": "#E53E3E",
      "dark": "#FC8181"
    },
    "accentSecondary": {
      "light": "#DD6B20",
      "dark": "#FBD38D"
    },
    "success": {
      "light": "#38A169",
      "dark": "#68D391"
    },
    "warning": {
      "light": "#D69E2E",
      "dark": "#F6E05E"
    },
    "error": {
      "light": "#E53E3E",
      "dark": "#FC8181"
    },
    "info": {
      "light": "#3182CE",
      "dark": "#63B3ED"
    }
  },
  "defaultTheme": "dark",
  "customCss": "custom.css",
  "fonts": {
    "body": "Inter, SF Pro Display, -apple-system, BlinkMacSystemFont, Segoe UI, Roboto, sans-serif",
    "code": "JetBrains Mono, SF Mono, Fira Code, Cascadia Code, monospace"
  },
  "borderRadius": "0.5rem",
  "codeTheme": {
    "light": "github-light",
    "dark": "one-dark-pro"
  }
}
